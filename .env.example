# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=[elastic_password]

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_SYSTEM_PASSWORD=[kibana_password]

# Token for Kibana TLS mode.
# Optional if you run scripts/deploy.sh with --auto-token.
# Auto-generated token is session-only unless --persist-token is used.
ELASTIC_SERVICE_TOKEN=[SERVICE_TOKEN]

# Version of Elastic products
STACK_VERSION=9.3.0

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200

# Port to expose Kibana HTTP API to the host
KIBANA_PORT=5601

# Docker project name
COMPOSE_PROJECT_NAME=elk
