{
  "rule_id": "nginx_sensitive_file_access",
  "name": "Nginx Sensitive File Access Attempt",
  "hypothesis": "Reconnaissance and exploitation workflows frequently request exposed configuration and secret files such as .git config, wp-config, or backup env files.",
  "source": "nginx.access",
  "severity": "high",
  "detection_logic": {
    "type": "regex_any",
    "fields": [
      "url.path"
    ],
    "patterns": [
      "^/(?:\\.git/config|wp-config\\.php|\\.env(?:\\.backup)?|backup\\.sql)$"
    ],
    "case_insensitive": true
  },
  "required_fields": [
    "event.original",
    "source.ip",
    "url.path",
    "http.response.status_code"
  ],
  "mitre": {
    "tactic": "Reconnaissance",
    "technique_id": "T1595",
    "technique": "Active Scanning"
  },
  "false_positives": [
    "Intentional security validation by trusted teams",
    "Controlled staging environment checks"
  ],
  "tuning": {
    "allowlist_source_ips": [],
    "sensitive_path_regex": "^/(?:\\.git/config|wp-config\\.php|\\.env(?:\\.backup)?|backup\\.sql)$"
  },
  "references": [
    "https://attack.mitre.org/techniques/T1595/"
  ],
  "playbook": "config/detections/nginx/playbooks/nginx_sensitive_file_access.md"
}
