{
  "rule_id": "nginx_command_injection_query",
  "name": "Nginx Command Injection Query Probe",
  "hypothesis": "Remote command injection probes in web requests often include shell metacharacters and command tokens inside query parameters.",
  "source": "nginx.access",
  "severity": "high",
  "detection_logic": {
    "type": "regex_any",
    "fields": [
      "url.original",
      "url.query"
    ],
    "patterns": [
      "%3[bB]cat%20/etc/passwd",
      "%7[cC]id",
      "%60whoami%60",
      "(?:;|\\|)`?(?:id|whoami|uname)`?"
    ],
    "case_insensitive": true
  },
  "required_fields": [
    "event.original",
    "source.ip",
    "url.original",
    "url.query",
    "http.response.status_code"
  ],
  "mitre": {
    "tactic": "Initial Access",
    "technique_id": "T1190",
    "technique": "Exploit Public-Facing Application"
  },
  "false_positives": [
    "Security validation payload replay in a lab",
    "Known red-team command injection testing"
  ],
  "tuning": {
    "allowlist_source_ips": [],
    "allowlist_query_prefixes": []
  },
  "references": [
    "https://attack.mitre.org/techniques/T1190/"
  ],
  "playbook": "config/detections/nginx/playbooks/nginx_command_injection_query.md"
}
