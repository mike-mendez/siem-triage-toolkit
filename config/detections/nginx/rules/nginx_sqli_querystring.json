{
  "rule_id": "nginx_sqli_querystring",
  "name": "Nginx SQLi Pattern in Query String",
  "hypothesis": "Attackers probing SQL injection will place tautology, UNION, or time-delay payload fragments in URL query parameters.",
  "source": "nginx.access",
  "severity": "medium",
  "detection_logic": {
    "type": "regex_any",
    "fields": ["url.original", "url.query"],
    "patterns": [
      "(?:%27|\\'|')(?:%20|\\s)*or(?:%20|\\s)*1(?:%3[dD]|=)1",
      "union(?:%20|\\s)+select",
      "sleep\\s*\\(",
      "information_schema"
    ],
    "case_insensitive": true
  },
  "required_fields": [
    "event.original",
    "source.ip",
    "http.request.method",
    "url.original",
    "url.query",
    "http.response.status_code",
    "user_agent.original"
  ],
  "mitre": {
    "tactic": "Initial Access",
    "technique_id": "T1190",
    "technique": "Exploit Public-Facing Application"
  },
  "false_positives": [
    "Internal security scanning and DAST tools",
    "Application QA traffic replaying attack test payloads"
  ],
  "tuning": {
    "allowlist_path_prefixes": ["/qa/", "/security-test/"],
    "allowlist_source_ips": []
  },
  "references": ["https://attack.mitre.org/techniques/T1190/"],
  "playbook": "config/detections/nginx/playbooks/nginx_sqli_querystring.md"
}
