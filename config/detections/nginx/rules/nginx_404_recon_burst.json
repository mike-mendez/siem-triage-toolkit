{
  "rule_id": "nginx_404_recon_burst",
  "name": "Nginx 404 Recon Burst to Sensitive Paths",
  "hypothesis": "Automated reconnaissance against exposed web apps will generate bursty 404 patterns across high-value admin and secret-related routes from a single source.",
  "source": "nginx.access",
  "severity": "medium",
  "detection_logic": {
    "type": "threshold_count",
    "group_by": "source.ip",
    "where": [
      {
        "field": "http.response.status_code",
        "equals": 404
      },
      {
        "field": "url.path",
        "regex": "^/(wp-admin|wp-login\\.php|\\.env|phpmyadmin|admin)/?$"
      }
    ],
    "case_insensitive": true,
    "min_count": 5
  },
  "required_fields": [
    "event.original",
    "source.ip",
    "url.path",
    "http.response.status_code"
  ],
  "mitre": {
    "tactic": "Reconnaissance",
    "technique_id": "T1595",
    "technique": "Active Scanning"
  },
  "false_positives": [
    "Internal vulnerability scanner hitting common admin paths",
    "Developer QA scripts targeting known nonexistent paths"
  ],
  "tuning": {
    "threshold_min_count": 5,
    "sensitive_path_regex": "^/(wp-admin|wp-login\\.php|\\.env|phpmyadmin|admin)/?$",
    "allowlist_source_ips": []
  },
  "references": ["https://attack.mitre.org/techniques/T1595/"],
  "playbook": "config/detections/nginx/playbooks/nginx_404_recon_burst.md"
}
